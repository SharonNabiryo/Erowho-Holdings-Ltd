{
  "version": 2,
  "builds": [
    { "src": "backend/app.py", "use": "@vercel/python" },
    { "src": "frontend/dist/index.html", "use": "@vercel/static" },
    { "src": "frontend/dist/bundle.js",  "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)",  "dest": "backend/app.py" },
    { "src": "/bundle.js", "dest": "frontend/dist/bundle.js" },
    { "src": "/(.*)",      "dest": "frontend/dist/index.html" }
  ]
}

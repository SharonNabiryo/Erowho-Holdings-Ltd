# Erowho Holdings Limited — Environment Variables
# Copy this file to .env and fill in values before running in production.
# Never commit .env to version control.

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret

# ── Admin credentials ─────────────────────────────────────────────────────────
# Default credentials are for local development only.
# Change before deploying to production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default): sqlite:///path/to/erowho.db
# On Vercel the backend automatically uses /tmp/erowho.db (ephemeral).
# For persistent storage, point to a managed database.
DATABASE_URL=sqlite:///backend/erowho.db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In development, localhost origins are allowed by default.
# In production, set this to your deployed domain(s).
ALLOWED_ORIGINS=https://your-domain.vercel.app

# ── JWT token lifetime ────────────────────────────────────────────────────────
# Seconds until admin tokens expire. Default: 604800 (7 days).
TOKEN_TTL_SECONDS=604800

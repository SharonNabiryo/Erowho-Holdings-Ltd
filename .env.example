# Erowho Holdings Limited — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# .env is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret. Generate with: openssl rand -hex 32
# Must be a long, random string in production.
SECRET_KEY=replace_me_with_a_long_random_secret

# ── Admin credentials ─────────────────────────────────────────────────────────
# TEMPORARY DEMO ACCESS ONLY — admin/admin123 is the local development default.
# Replace with strong credentials before any real deployment.
# Change the password via the admin dashboard after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local development):
DATABASE_URL=sqlite:///backend/erowho.db
#
# On Vercel, the app automatically uses /tmp/erowho.db (writable but ephemeral).
# Data is lost on every cold start — acceptable for demo, not for real data.
#
# For persistent production data, use Supabase Postgres:
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# (Full Postgres support requires SQLAlchemy + psycopg2-binary — see README)

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In development, localhost origins are allowed by default even if this is empty.
# In production, set this to your deployed domain(s).
ALLOWED_ORIGINS=http://localhost:5001,http://localhost:5173,http://localhost:3000

# ── JWT token lifetime ────────────────────────────────────────────────────────
TOKEN_TTL_SECONDS=604800

# ── Frontend API base URL (optional) ─────────────────────────────────────────
# Set this at build time to override the API base URL in the frontend bundle.
# Leave empty to use the runtime window.API_BASE injection from index.html.
# Only needed if migrating to Vite or a separate frontend deploy.
VITE_API_BASE_URL=

# ── Supabase (fill in after creating your Supabase project) ──────────────────
# These are not yet used by the backend but are included here for reference.
# The backend will use DATABASE_URL (postgres:// string) once SQLAlchemy
# support is added. The keys below are for Supabase client-side SDK usage
# or future server-side Supabase integrations.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name for property images (bucket must be set to public)
SUPABASE_STORAGE_BUCKET=property-images
